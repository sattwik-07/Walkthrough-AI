function saveItinerary() {
  if (!lastItinData) { showToast('Generate an itinerary first.'); return; }
  const saved = JSON.parse(localStorage.getItem('wth_saved_itins') || '[]');
  saved.unshift({ ...lastItinData, savedAt: new Date().toISOString() });
  localStorage.setItem('wth_saved_itins', JSON.stringify(saved.slice(0, 20)));
  showToast('✓ Itinerary saved to your library!');
}

async function shareItinerary() {
  if (!lastItinData) { showToast('Generate an itinerary first.'); return; }
  const text = `🏛 ${lastItinData.data.title || lastItinData.dest + ' Heritage Journey'}\n${lastItinData.data.tagline || ''}\n\nPlanned with Walk Through History`;
  try {
    if (navigator.share) {
      await navigator.share({ title: 'My Heritage Itinerary', text });
    } else {
      await navigator.clipboard.writeText(text);
      showToast('✓ Itinerary text copied to clipboard!');
    }
  } catch { showToast('✓ Copied to clipboard!'); }
}

