function showMdetailImg(wrap, m, url) {
  const badgeBg    = m.badge === 'unesco' ? '#1a6fc4' : 'rgba(212,168,67,0.9)';
  const badgeColor = m.badge === 'unesco' ? '#fff'    : '#0d1117';
  const badgeText  = m.badge === 'unesco' ? 'UNESCO'  : 'Heritage';
  wrap.style.position = 'relative';
  wrap.innerHTML = `
    <img src="${url}" alt="${m.name}" class="mdetail-img"
      onerror="this.style.display='none';this.nextElementSibling.style.display='flex';">
    <div class="mdetail-img-placeholder" style="display:none;">🏛</div>
    <span style="position:absolute;top:14px;left:16px;z-index:10;padding:4px 12px;border-radius:4px;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;background:${badgeBg};color:${badgeColor};">
      ${badgeText}
    </span>`;
}

function openMonument(id) {
  const m = monuments.find(x => x.id === id);
  if (!m) return;
  const d = monumentDetails[id] || {};

  // Image — try card image first (already loaded), then fetch Wikipedia
  const imgWrap = document.getElementById('mdetailImgWrap');
  imgWrap.style.position = 'relative';
  imgWrap.innerHTML = `<div class="mdetail-img-placeholder">🏛</div>`;

  // Check if the card img for this monument already has a src loaded
  const cardImg = document.querySelector(`#cimg-${m.id} img`);
  if (cardImg && cardImg.src && !cardImg.src.endsWith(location.href)) {
    // Reuse the already-loaded card image
    showMdetailImg(imgWrap, m, cardImg.src.replace(/\/\d+px-/, '/800px-'));
  } else if (imgCache[m.wiki]) {
    showMdetailImg(imgWrap, m, imgCache[m.wiki].replace(/\/\d+px-/, '/800px-'));
  } else if (m.wiki) {
    fetch(`https://en.wikipedia.org/api/rest_v1/page/summary/${m.wiki}`, { headers: { 'Accept': 'application/json' } })
      .then(r => r.json())
      .then(data => {
        const url = data?.originalimage?.source || data?.thumbnail?.source;
        if (url) {
          imgCache[m.wiki] = url;
          showMdetailImg(imgWrap, m, url.replace(/\/\d+px-/, '/800px-'));
        }
      }).catch(() => {});
  }

  // Tags, title, location
  document.getElementById('mdetailTags').innerHTML = m.tags.map(t => `<span class="mdetail-tag">${t}</span>`).join('');
  document.getElementById('mdetailTitle').textContent = m.name;
  document.getElementById('mdetailLocation').innerHTML = `📍 ${m.location} <span class="mdetail-rating"><span class="star">★</span> ${m.rating} / 5.0</span>`;

  // Description
  document.getElementById('mdetailDesc').textContent = d.fullDesc || m.desc;

  // Facts
  const facts = [
    d.built    ? { label: 'Built', value: d.built }           : null,
    d.dynasty  ? { label: 'Dynasty / Era', value: d.dynasty } : null,
    d.builder  ? { label: 'Builder', value: d.builder }       : null,
    d.type     ? { label: 'Type', value: d.type }             : null,
    d.entry    ? { label: 'Entry Fee', value: d.entry }       : null,
    d.timings  ? { label: 'Timings', value: d.timings }       : null,
  ].filter(Boolean);
  document.getElementById('mdetailFacts').innerHTML = facts.map(f => `
    <div class="mdetail-fact">
      <div class="mdetail-fact-label">${f.label}</div>
      <div class="mdetail-fact-value">${f.value}</div>
    </div>`).join('');

  // Highlights
  const highlights = d.highlights || [m.desc];
  document.getElementById('mdetailHighlights').innerHTML = highlights.map(h => `
    <div class="mdetail-highlight">
      <div class="mdetail-highlight-dot"></div>
      <span>${h}</span>
    </div>`).join('');

  // Tips
  document.getElementById('mdetailTips').textContent = d.tips || 'Check local tourism websites for the latest timings and entry fees before visiting.';

  // ─── 3D MODEL ───────────────────────────────────────────────
  const modelId = monument3D[id];
  const section = document.getElementById('mdetail3DSection');
  if (modelId) {
    section.style.display = 'block';
    document.getElementById('mdetail3DName').textContent = m.name + ' — Interactive 3D Model';
    document.getElementById('mdetail3DLink').href = `https://skfb.ly/${modelId}`;
  } else {
    section.style.display = 'none';
  }

  // Open modal
  document.getElementById('mdetailModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}

