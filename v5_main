let filtered = [...monuments].sort((a,b) => {
  const a3d = !!monument3D[a.id] ? 0 : 1;
  const b3d = !!monument3D[b.id] ? 0 : 1;
  if (a3d !== b3d) return a3d - b3d;
  return a.id - b.id;
});
const INITIAL_COUNT = 4;
const LOAD_MORE_COUNT = 8;
let visibleCount = INITIAL_COUNT;

// ── Wikipedia image cache & fetcher ──────────────────────────
const imgCache = {};

async function fetchWikiImg(title, imgEl, placeholder) {
  if (imgCache[title]) {
    applyImg(imgEl, placeholder, imgCache[title]);
    return;
  }
  try {
    const res = await fetch(
      `https://en.wikipedia.org/api/rest_v1/page/summary/${title}`,
      { headers: { 'Accept': 'application/json' } }
    );
    const data = await res.json();
    const url = data?.thumbnail?.source || data?.originalimage?.source || null;
    imgCache[title] = url;
    applyImg(imgEl, placeholder, url);
  } catch(e) {
    showPlaceholder(placeholder);
  }
}

function applyImg(imgEl, placeholder, url) {
  if (!url) { showPlaceholder(placeholder); return; }
  // Make image larger/higher quality
  const bigger = url.replace(/\/\d+px-/, '/600px-');
  imgEl.src = bigger;
  imgEl.style.display = 'block';
  imgEl.onload = () => { placeholder.style.display = 'none'; };
  imgEl.onerror = () => { imgEl.style.display='none'; showPlaceholder(placeholder); };
}

function showPlaceholder(el) {
  el.innerHTML = '<span style="font-size:2.8rem">🏛</span>';
  el.style.display = 'flex';
}

function cardHTML(m, i) {
  const has3D = !!monument3D[m.id];
  return `
    <div class="monument-card" style="animation-delay:${i*0.07}s" onclick="openMonument(${m.id})">
      <div class="card-img" id="cimg-${m.id}">
        <img data-wiki="${m.wiki}" alt="${m.name}" style="display:none;width:100%;height:100%;object-fit:cover;transition:transform 0.4s">
        <div class="card-img-placeholder" style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#1c2535 0%,#0d1117 100%)">
          <span style="font-size:2.8rem;opacity:0.35">🏛</span>
        </div>
        <span class="card-badge badge-${m.badge}">${m.badge === 'unesco' ? 'UNESCO' : 'Heritage'}</span>
        ${has3D ? `<span style="position:absolute;top:12px;right:44px;background:rgba(212,168,67,0.9);color:#0d1117;font-size:9px;font-weight:700;padding:2px 7px;border-radius:4px;letter-spacing:0.06em;">3D</span>` : ''}
        <button class="card-save" onclick="event.stopPropagation();" title="Save">🔖</button>
        <div class="card-overlay"></div>
        <div class="card-location">📍 ${m.location}</div>
      </div>
      <div class="card-body">
        <div class="card-tags">${m.tags.map(t=>`<span class="card-tag">${t}</span>`).join('')}</div>
        <h3 class="card-name">${m.name}</h3>
        <p class="card-desc">${m.desc}</p>
        <div class="card-footer">
          <div class="card-rating"><span class="star">★</span> ${m.rating} / 5.0</div>
          <span class="card-cta">${has3D ? '🏛 Explore + 3D →' : 'Explore →'}</span>
        </div>
      </div>
    </div>`;
}

function loadCardImages(container) {
  container.querySelectorAll('img[data-wiki]').forEach(imgEl => {
    const wiki = imgEl.getAttribute('data-wiki');
    const placeholder = imgEl.nextElementSibling;
    fetchWikiImg(wiki, imgEl, placeholder);
  });
}

function renderMonuments() {
  const grid = document.getElementById('monumentsGrid');
  const visible = filtered.slice(0, visibleCount);
  const remaining = filtered.length - visibleCount;
  const wrap = document.getElementById('showMoreWrap');

  document.getElementById('countLabel').textContent = `${visible.length} of ${filtered.length}`;

  // Render only newly added cards to avoid re-animating existing ones
  grid.innerHTML = visible.map((m, i) => cardHTML(m, i)).join('');
  loadCardImages(grid);

  // Show/hide buttons
  const lessBtn = document.getElementById('showLessBtn');
  const moreBtn = document.getElementById('showMoreBtn');
  const canShowLess = visibleCount > INITIAL_COUNT;
  if (remaining > 0 || canShowLess) {
    wrap.style.display = 'block';
    lessBtn.style.display = canShowLess ? 'inline-block' : 'none';
    moreBtn.style.display = remaining > 0 ? 'inline-block' : 'none';
    if (remaining > 0) {
      const nextBatch = Math.min(remaining, LOAD_MORE_COUNT);
      document.getElementById('showMoreCount').textContent = `${nextBatch} Monuments`;
      document.getElementById('showMoreMeta').textContent = `${remaining} more monument${remaining !== 1 ? 's' : ''} to explore`;
    } else {
      document.getElementById('showMoreMeta').textContent = `Showing all ${filtered.length} monuments`;
    }
  } else {
    wrap.style.display = 'none';
  }
}

function showMore() {
  const grid = document.getElementById('monumentsGrid');
  const prevCount = visibleCount;
  visibleCount = Math.min(visibleCount + LOAD_MORE_COUNT, filtered.length);

  // Append only the new cards with animation
  const newItems = filtered.slice(prevCount, visibleCount);
  newItems.forEach((m, i) => {
    const div = document.createElement('div');
    div.innerHTML = cardHTML(m, prevCount + i).trim();
    const card = div.firstChild;
    grid.appendChild(card);
  });
  loadCardImages(grid);

  const remaining = filtered.length - visibleCount;
  const wrap = document.getElementById('showMoreWrap');
  document.getElementById('countLabel').textContent = `${visibleCount} of ${filtered.length}`;

  const lessBtn2 = document.getElementById('showLessBtn');
  const moreBtn2 = document.getElementById('showMoreBtn');
  lessBtn2.style.display = 'inline-block';
  if (remaining > 0) {
    wrap.style.display = 'block';
    moreBtn2.style.display = 'inline-block';
    const nextBatch = Math.min(remaining, LOAD_MORE_COUNT);
    document.getElementById('showMoreCount').textContent = `${nextBatch} Monuments`;
    document.getElementById('showMoreMeta').textContent = `${remaining} more monument${remaining !== 1 ? 's' : ''} to explore`;
  } else {
    moreBtn2.style.display = 'none';
    document.getElementById('showMoreMeta').textContent = `Showing all ${filtered.length} monuments`;
  }
}

function showLess() {
  visibleCount = Math.max(visibleCount - LOAD_MORE_COUNT, INITIAL_COUNT);
  renderMonuments();
  // Scroll back up to the monuments section smoothly
  document.querySelector('.monuments-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function setFilter(el, f) {
  currentFilter = f;
  visibleCount = INITIAL_COUNT;
  document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  applyFilters();
}

function filterMonuments() {
  visibleCount = INITIAL_COUNT;
  applyFilters();
}

function applyFilters() {
  const query = document.getElementById('searchInput').value.toLowerCase();
  // When searching, show all results immediately
  const isSearching = query.length > 0;
  filtered = monuments.filter(m => {
    const matchQuery = !query || m.name.toLowerCase().includes(query) || m.location.toLowerCase().includes(query) || m.tags.some(t => t.toLowerCase().includes(query));
    const matchFilter = currentFilter === 'all' || m.type.includes(currentFilter);
    return matchQuery && matchFilter;
  });
  if (isSearching) visibleCount = filtered.length; // show all search results
  sortMonuments(currentSort);
  renderMonuments();
}

function sortMonuments(val) {
  currentSort = val;
  if (val === 'name') filtered.sort((a,b) => a.name.localeCompare(b.name));
  else if (val === 'rating') filtered.sort((a,b) => b.rating - a.rating);
  else if (val === 'era') filtered.sort((a,b) => a.id - b.id);
  else {
    // Default: monuments WITH 3D model first, then rest
    filtered.sort((a,b) => {
      const a3d = !!monument3D[a.id] ? 0 : 1;
      const b3d = !!monument3D[b.id] ? 0 : 1;
      if (a3d !== b3d) return a3d - b3d;
      return a.id - b.id;
    });
  }
  renderMonuments();
}

function setView(btn, view) {
  document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const grid = document.getElementById('monumentsGrid');
  if (view === 'list') {
    grid.style.gridTemplateColumns = '1fr';
  } else {
    grid.style.gridTemplateColumns = 'repeat(auto-fill, minmax(320px, 1fr))';
  }
}

function closeMdetail() {
  document.getElementById('mdetailModal').classList.remove('open');
  document.body.style.overflow = '';
}
const monumentDetails = {
  1:  { built:'1632–1653 CE', dynasty:'Mughal', builder:'Emperor Shah Jahan', type:'Mausoleum', entry:'₹50 (Indian) / ₹1,100 (Foreign)', timings:'Sunrise to Sunset (Closed Friday)', fullDesc:'The Taj Mahal is an ivory-white marble mausoleum on the southern bank of the river Yamuna in Agra. Commissioned in 1632 by Mughal emperor Shah Jahan to house the tomb of his beloved wife Mumtaz Mahal, it also houses Shah Jahan\'s tomb. The tomb is the centrepiece of a 17-hectare complex which includes a mosque and a guest house. It is considered the finest example of Mughal architecture, a blend of Indian, Persian, and Islamic styles.', highlights:['The central dome stands 73 metres tall and is surrounded by four smaller domed kiosks','The entire structure is built with translucent white Makrana marble that changes colour with the light','Intricate pietra dura inlays feature lapis lazuli, jade, crystal, turquoise and amethyst','The four minarets are slightly tilted outward so they fall away from the tomb in case of an earthquake','Over 20,000 artisans, craftsmen, and labourers worked for 22 years to complete it'], tips:'Visit at sunrise for the most magical light and minimal crowds. The full moon viewing (5 nights around full moon) is a special ticketed event. Avoid Fridays as it is closed. The marble glows pink at dawn, white at noon, and golden at sunset.' },
  2:  { built:'1638–1648 CE', dynasty:'Mughal', builder:'Emperor Shah Jahan', type:'Fort / Palace', entry:'₹35 (Indian) / ₹500 (Foreign)', timings:'9:30 AM – 4:30 PM (Closed Monday)', fullDesc:'The Red Fort is a historic fort complex built by Mughal Emperor Shah Jahan as the palace for his new capital Shahjahanabad in Old Delhi. Named for its massive walls of red sandstone, it is the site from which India\'s Prime Minister hoists the flag on Independence Day. The fort contains several palaces including Diwan-i-Am (Hall of Public Audience) and Diwan-i-Khas (Hall of Private Audience), along with museums and the iconic Lahori Gate.', highlights:['The octagonal Musamman Burj tower was where Shah Jahan spent his final years under house arrest','Diwan-i-Khas once housed the legendary Peacock Throne and the Koh-i-Noor diamond','The Nahr-i-Bihisht (Stream of Paradise) canal once ran through all the palace chambers','The fort covers 254.67 acres and has two main gates — Lahori Gate and Delhi Gate','India\'s Independence Day flag hoisting ceremony has been held here since 1947'], tips:'Book the Sound & Light Show in the evenings for a spectacular history narration. The Lahori Gate is the main entrance. Arrive early to beat the crowds, especially on weekends.' },
  3:  { built:'1193 CE', dynasty:'Delhi Sultanate', builder:'Qutb ud-Din Aibak', type:'Minaret Complex', entry:'₹35 (Indian) / ₹550 (Foreign)', timings:'Sunrise to Sunset (All days)', fullDesc:'The Qutb Minar is a minaret and UNESCO World Heritage Site in the Mehrauli area of Delhi. At 72.5 metres, it is the tallest minaret in India and one of the earliest examples of Indo-Islamic architecture. The minaret has 379 stairs and features bands of ornate carvings and verses from the Quran. Also in the complex is the Iron Pillar of Delhi — a 7-metre iron pillar dating from the 4th or 5th century CE that has never rusted.', highlights:['The 7m Iron Pillar has stood for 1,600 years without rusting — a metallurgical mystery', 'The tower tapers from 14.3 metres diameter at base to 2.7 metres at top', 'The complex also contains the incomplete Alai Minar — which was to be twice the height', 'Quwwat-ul-Islam mosque nearby was the first mosque built in India after the Islamic conquest', 'The sandstone changes from dark red to buff-coloured marble as it rises'], tips:'The complex is best explored in the morning when the light is soft on the sandstone. The Iron Pillar legend says circling it with arms behind your back brings good luck. Allow 2–3 hours for the full complex.' },
  4:  { built:'14th–16th century CE', dynasty:'Vijayanagara Empire', builder:'Multiple Rulers', type:'Ruined Capital', entry:'₹40 (Indian) / ₹600 (Foreign)', timings:'Sunrise to Sunset (All days)', fullDesc:'Hampi is an ancient village in the south Indian state of Karnataka. It was the capital of the Vijayanagara Empire — the last great Hindu empire — before being abandoned after the Battle of Talikota in 1565. It is now a UNESCO World Heritage Site spread over 4,000+ acres among a surreal boulder-strewn landscape on the banks of the Tungabhadra River. The ruins include over 1,600 monuments including temples, pavilions, elephant stables, market streets and royal palaces.', highlights:['Vittala Temple\'s iconic stone chariot is depicted on the Indian 50-rupee note','The Stone Chariot\'s wheels were once capable of moving — they were later cemented','Musical Pillars in the Vittala Temple produce musical sounds when struck','The Virupaksha Temple has been in continuous use for over 700 years','Matanga Hill offers the best 360° panoramic view of the entire ruins at sunrise'], tips:'Rent a bicycle or hire an auto to cover the vast spread of ruins. Start with Virupaksha Temple at sunrise, visit Vittala Temple mid-morning before crowds arrive. The Coracle boat ride across the Tungabhadra is a must-do experience.' },
  5:  { built:'950–1050 CE', dynasty:'Chandela Dynasty', builder:'Various Chandela Rulers', type:'Temple Complex', entry:'₹40 (Indian) / ₹600 (Foreign)', timings:'Sunrise to Sunset (All days)', fullDesc:'The Khajuraho Group of Monuments is a group of Hindu and Jain temples in Madhya Pradesh, famous for their Nagara-style architecture and erotic sculptures. Of the original 85 temples built by the Chandela dynasty between 950 and 1050 CE, only about 25 temples remain. The temples are divided into three groups — Western, Eastern and Southern. The famous erotic carvings constitute only about 10% of all sculpture — the rest depict gods, apsaras, celestial nymphs, and scenes from daily life.', highlights:['Only about 10% of carvings are erotic — the majority depict everyday life and deities', 'The Kandariya Mahadeva temple is the largest and most ornate with over 900 sculptures', 'Temples are built on high platforms (jagati) with soaring shikhara towers', 'The sculptures are celebrated as some of the finest medieval art in the world', 'No mortar was used in construction — stones are precisely interlocked'], tips:'The Light and Sound Show at the Western Group is highly recommended. The Western temples are the most impressive and best preserved. Hire a guide to understand the philosophy behind the sculptures. Best visited between October and March.' },
  6:  { built:'1460 CE', dynasty:'Rathore Rajputs', builder:'Rao Jodha', type:'Fort', entry:'₹100 (Indian) / ₹600 (Foreign)', timings:'9:00 AM – 5:00 PM (All days)', fullDesc:'Mehrangarh Fort is one of the largest forts in India, situated 410 feet above Jodhpur. Founded by Rao Jodha in 1460, the fort has withstood many sieges and contains several palaces with exquisitely carved panels, latticed windows, and extensive courtyards. The fort museum houses an extensive collection of palanquins, howdahs, royal cradles, miniature paintings, costumes, and armour. The walls bear cannonball marks from attacks by the armies of Jaipur.', highlights:['The walls rise up to 36 metres thick in some places', 'Chamunda Mata Temple inside the fort is over 500 years old', 'The fort\'s Moti Mahal (Pearl Palace) has 5 niches where the Maharaja\'s 5 queens could watch court proceedings unseen', 'There are 7 gates including the famous Jai Pol built to celebrate victory over Jaipur', 'Zipline across the fort is one of India\'s highest and longest'], tips:'Visit the museum to see the incredible royal collection. The fort battlements offer the best views of Jodhpur\'s blue-painted houses. The rooftop café has excellent views. A zipline and guided audio tour are available.' },
  7:  { built:'1799 CE', dynasty:'Rajput', builder:'Maharaja Sawai Pratap Singh', type:'Palace', entry:'₹50 (Indian) / ₹200 (Foreign)', timings:'9:00 AM – 5:30 PM (All days)', fullDesc:'Hawa Mahal, or the Palace of Winds, is a palace in Jaipur built from red and pink sandstone. It was built in 1799 by Maharaja Sawai Pratap Singh and designed by Lal Chand Ustad in the form of the crown of Lord Krishna. The five-story exterior has 953 small windows called jharokhas decorated with intricate latticework, designed to allow royal women to observe everyday life and processions on the street below without being seen.', highlights:['953 small windows create a natural air-conditioning effect — hence "Palace of Winds"', 'The façade is only 1.5 metres deep — it is essentially a very ornate screen wall', 'No staircase exists in the building — you access upper floors via ramps', 'It forms the largest example of Rajputana architecture', 'At sunrise the entire facade glows in warm golden light — best photography time'], tips:'The best view of Hawa Mahal is from the street or a rooftop café across the road. The inside has a small museum. Visit early morning for photography. The nearby Johari Bazaar is excellent for gemstones and jewellery.' },
  8:  { built:'2nd century BCE – 6th century CE', dynasty:'Various', builder:'Buddhist Monks', type:'Cave Monuments', entry:'₹40 (Indian) / ₹600 (Foreign)', timings:'9:00 AM – 5:30 PM (Closed Monday)', fullDesc:'The Ajanta Caves are 30 rock-cut Buddhist cave monuments in the Aurangabad district of Maharashtra. Carved between the 2nd century BCE and 480 CE, they contain some of the greatest surviving examples of ancient Indian art, particularly the murals which are considered masterpieces of Buddhist religious art. The paintings depict the Jataka tales (stories of the Buddha\'s past lives) and are extraordinary for their fluidity and detail. The caves were forgotten for over a thousand years before being rediscovered in 1819 by a British officer.', highlights:['The murals use natural pigments that have survived for over 1,500 years', 'Cave 1 features the famous Bodhisattva Padmapani — one of the finest paintings in the world', 'The caves were carved top-down by removing rock from the hillside', 'A British hunting party rediscovered the caves in 1819 when they stumbled upon them', 'The paintings glow with a rare luminosity due to a unique polishing technique'], tips:'Carry a torch or phone flashlight to see the paintings clearly. Hire an ASI guide at the entrance for detailed explanations. Visit on weekdays to avoid crowds. The semicircular layout means you walk about 5 km to see all caves.' },
  9:  { built:'600–1000 CE', dynasty:'Rashtrakuta / Yadava', builder:'Multiple Rulers', type:'Cave Complex', entry:'₹40 (Indian) / ₹600 (Foreign)', timings:'9:00 AM – 5:30 PM (Closed Tuesday)', fullDesc:'The Ellora Caves are a UNESCO World Heritage Site and one of the largest rock-cut monastery-temple cave complexes in the world. Unlike Ajanta which is purely Buddhist, Ellora features 34 caves representing Buddhism, Hinduism and Jainism side by side, symbolising the religious harmony of ancient India. The most remarkable is Cave 16 — the Kailasa Temple — which is not a cave at all but an entire temple carved from a single rock from the top down. The volume of rock removed to carve it is estimated at 200,000 tonnes.', highlights:['The Kailasa Temple (Cave 16) is the largest monolithic rock-cut structure in the world', 'Over 200,000 tonnes of rock were removed to carve the Kailasa Temple', 'The temple was built top-down — carved by removing rock from the top of the hillside', 'Buddhist, Hindu and Jain caves co-exist side by side over a 2km stretch', 'It took 150+ years and 7,000 labourers to complete the Kailasa Temple'], tips:'Start with the Kailasa Temple (Cave 16) which is the unmissable centerpiece. Caves 1-12 are Buddhist, 13-29 Hindu, 30-34 Jain. Hire a guide for the Kailasa Temple — its mythology is extraordinary. Best in morning light.' },
  10: { built:'1924 CE', dynasty:'British Raj', builder:'George Wittet', type:'Arch Monument', entry:'Free', timings:'24 Hours (All days)', fullDesc:'The Gateway of India is an arch monument built during the British Raj in Mumbai, overlooking the Arabian Sea. It was erected to commemorate the visit of King George V and Queen Mary to Bombay in 1911. The monument was also the last point from which the last British troops departed India in 1948 after Indian independence. Built in Indo-Saracenic style, combining elements of Hindu and Muslim architecture, it stands 26 metres tall and faces the Taj Mahal Palace Hotel across the water.', highlights:['It was the formal entry and exit point for all Viceroys arriving in India', 'The last British regiment — the Somerset Light Infantry — sailed through it in 1948', 'Ferry boats to Elephanta Caves depart from the jetty here', 'The Taj Mahal Palace Hotel across the road was built because Indians were denied entry to colonial hotels', 'The arch was built from yellow basalt and reinforced concrete'], tips:'Best visited at dusk when the monument is illuminated and the sea breeze is pleasant. The harbour boat rides at sunset offer excellent photo angles. Elephanta Cave ferry leaves from here — combine both in one trip.' },
  11: { built:'1589 CE (current structure)', dynasty:'Sikh Empire', builder:'Guru Arjan Dev', type:'Gurdwara', entry:'Free', timings:'Open 24 Hours (All days)', fullDesc:'Harmandir Sahib, popularly known as the Golden Temple, is the holiest Gurdwara of Sikhism, located in Amritsar. The lower half of the temple is built of white marble and the upper half is gilded in 750 kg of pure gold donated by Maharaja Ranjit Singh in the 19th century. The temple is built at a level lower than the surrounding land — symbolising humility — and is surrounded by the holy Amrit Sarovar (Pool of Nectar). The langar (community kitchen) serves free meals to over 100,000 people daily regardless of religion or caste.', highlights:['750 kg of pure gold covers the upper sanctum — donated by Maharaja Ranjit Singh', 'The langar (free kitchen) feeds over 100,000 people daily regardless of religion', 'The temple has four entrances — symbolising openness to all four directions and religions', 'The Amrit Sarovar (Pool of Nectar) was built by Guru Ram Das and expanded by Guru Arjan Dev', 'The Akal Takht across the sarovar is the highest seat of earthly authority in Sikhism'], tips:'The most magical time to visit is early morning (3–4 AM) when the Palki Sahib ceremony takes place and the reflection in the sarovar is breathtaking. Cover your head and remove shoes. The langar experience is deeply moving — do volunteer to serve.' },
  12: { built:'1565–1572 CE', dynasty:'Mughal', builder:'Bega Begum (wife of Humayun)', type:'Tomb / Garden', entry:'₹35 (Indian) / ₹550 (Foreign)', timings:'Sunrise to Sunset (All days)', fullDesc:'Humayun\'s Tomb is the tomb of the Mughal Emperor Humayun in Delhi. It was the first garden-tomb on the Indian subcontinent and inspired several major architectural innovations, notably the Taj Mahal. Built by Humayun\'s widow Empress Bega Begum, it was the first structure to use the double dome in India. The complex is a UNESCO World Heritage Site and exemplifies the Persian style of architecture mixed with Mughal elements. The complex contains the tombs of over 150 Mughal family members.', highlights:['First structure in India to use the double dome — a technique later perfected in the Taj Mahal', 'The garden is a classic charbagh — Persian four-quartered garden divided by water channels', 'Over 150 Mughal-era graves are within the complex', 'It served as the template for the Taj Mahal built 80 years later', 'The last Mughal emperor Bahadur Shah Zafar was captured here by the British in 1857'], tips:'Less crowded than Taj Mahal but architecturally just as impressive. The sunrise and golden hour light on the sandstone and marble is spectacular. Combine with nearby Isa Khan\'s tomb and the Sunder Nursery for a full day.' },
  13: { built:'1931 CE', dynasty:'British India', builder:'Edwin Lutyens', type:'War Memorial', entry:'Free', timings:'24 Hours (All days)', fullDesc:'India Gate is a war memorial located astride the Rajpath on the eastern edge of the ceremonial axis of New Delhi. Originally called the All India War Memorial, it was built to honour 82,000 soldiers of the British Indian Army who died in the First World War and the Third Anglo-Afghan War. The eternal flame Amar Jawan Jyoti burns beneath the arch in memory of soldiers who died in the 1971 Indo-Pakistani War. The 42-metre arch is modelled on the Arc de Triomphe in Paris.', highlights:['Names of 13,218 servicemen of the British Indian Army are inscribed on the arch', 'The Amar Jawan Jyoti has been burning continuously since 1972', 'It stands at the end of the 3km Rajpath ceremonial avenue leading to Rashtrapati Bhavan', 'The National War Memorial was added nearby in 2019', 'The lawns around India Gate are a beloved picnic spot for Delhiites'], tips:'Beautiful at night when illuminated. The best view is from the Rajpath looking westward toward Rashtrapati Bhavan. Visit during Republic Day preparations in January to see the entire ceremonial boulevard decorated.' },
  14: { built:'1156 CE', dynasty:'Bhati Rajputs', builder:'Rawal Jaisal', type:'Living Fort', entry:'₹50 (Indian) / ₹250 (Foreign)', timings:'9:00 AM – 6:00 PM (All days)', fullDesc:'Jaisalmer Fort, also called Sonar Quila or the Golden Fortress, is a World Heritage Site located in the city of Jaisalmer in Rajasthan. Rising 99 metres above the Thar Desert, it is one of the largest fully preserved fortified cities in the world. About 3,000 people still live within the fort, making it one of the very few "living forts" in the world. The fort is built from yellow Jurassic Thar sandstone which glows golden in the sunlight, giving it the name "Golden Fort".', highlights:['Still inhabited by about 3,000 people — one of the world\'s few living forts', 'The fort has 99 bastions, 92 of which are intact', 'The Jain temples inside the fort are intricately carved and over 800 years old', 'The stones turn golden at sunset — best photography time', 'The ancient havelis (mansions) inside have carved facades rivalling any palace'], tips:'Stay inside the fort for at least one night to experience the magical atmosphere after day-trippers leave. The fort illuminated at night is stunning. Visit the Jain temples early morning when priests perform prayers. The views from the ramparts at sunset are unforgettable.' },
  15: { built:'1592 CE', dynasty:'Rajput', builder:'Raja Man Singh I', type:'Fort', entry:'₹100 (Indian) / ₹500 (Foreign)', timings:'8:00 AM – 5:30 PM (All days)', fullDesc:'Amer Fort, also known as Amber Fort, is a fort located in Amer, Rajasthan. It was the seat of the Kachwaha Rajputs before Jaipur was built. The fort sits on a hill overlooking Maota Lake and the town of Amer. It is renowned for its artistic style that blends Hindu and Rajput elements. The fort has large ramparts, a series of gates and cobbled paths. The interior has a mix of the Diwan-e-Aam (hall of public audience), Diwan-e-Khas, Sheesh Mahal and Sukh Niwas.', highlights:['Sheesh Mahal (Hall of Mirrors) — ceiling covered with thousands of tiny mirror pieces that reflect like stars', 'Elephants and jeeps carry visitors up the steep hill to the main gate', 'The fort has a secret underground passage connecting it to Jaigarh Fort above', 'The Ganesh Pol gateway has some of the finest frescoes in Rajasthan', 'The fort was never defeated in battle during its active years'], tips:'Arrive before 8 AM to beat the crowds and get the fort mostly to yourself. The elephant ride up is controversial — jeeps are an ethical alternative. The Sheesh Mahal is the highlight — ask a guard to show you the mirror room with a single candle.' },
  16: { built:'1250 CE', dynasty:'Eastern Ganga Dynasty', builder:'King Narasimhadeva I', type:'Sun Temple', entry:'₹40 (Indian) / ₹600 (Foreign)', timings:'6:00 AM – 8:00 PM (All days)', fullDesc:'The Konark Sun Temple is a 13th-century CE UNESCO World Heritage Site at Konark in Odisha. The temple was built in the shape of a gigantic chariot with twelve pairs of intricately carved stone wheels pulled by seven horses, representing the chariot of Surya the Sun god. It is considered one of the greatest works of Orissan architecture and sculpture. The temple is also known as the Black Pagoda — it served as a landmark for sailors navigating the Bay of Bengal.', highlights:['The 12 pairs of wheels are astronomical sundials — you can read the exact time from the shadow', 'Seven horses represent the seven days of the week pulling the sun\'s chariot', 'The temple was built at 19.3° latitude aligning exactly with the path of the sun', 'The main sanctum tower has collapsed but the Jagamohana (audience hall) is still intact', 'The temple was called "Black Pagoda" by European sailors to contrast with the "White Pagoda" at Puri'], tips:'Watch the sunrise here for the extraordinary spectacle of the first light hitting the temple\'s carved stone. The Archaeological Survey museum on site has beautiful salvaged sculptures. Use the sundial wheels — they actually work!' },
  17: { built:'1906 CE', dynasty:'British Raj', builder:'William Emerson', type:'Monument / Museum', entry:'₹30 (Indian) / ₹500 (Foreign)', timings:'10:00 AM – 5:00 PM (Closed Monday)', fullDesc:'The Victoria Memorial is a large marble building in Kolkata, built between 1906 and 1921 as a monument to Queen Victoria. Now a museum under the Ministry of Culture, it houses a collection of 25 galleries with 28,394 artefacts relating to the colonial era, the Calcutta of the 1800s, and Queen Victoria\'s life. The building is built in the Indo-Saracenic Revivalist style using white Makrana marble (same as the Taj Mahal). The surrounding gardens are a beloved green space in central Kolkata.', highlights:['Built with the same Makrana marble from Rajasthan as the Taj Mahal', 'The bronze Angel of Victory on the central dome rotates with the wind', 'The museum holds Queen Victoria\'s writing desk, letters and personal belongings', 'The surrounding gardens were designed by Lord Curzon', 'It was funded entirely by Indians — the British levied a contribution on Indian princes'], tips:'The Sound and Light Show on the lawns at night brings the history to life magnificently. Visit the museum galleries for a fascinating window into colonial-era Calcutta. The gardens at dusk are beautiful. Combine with a walk down Park Street.' },
  18: { built:'1897 CE (current)', dynasty:'Wodeyar Dynasty', builder:'Henry Irwin', type:'Palace', entry:'₹100 (Indian) / ₹200 (Foreign)', timings:'10:00 AM – 5:30 PM (All days)', fullDesc:'Mysore Palace is the official residence of the Wadiyar dynasty and the seat of the Kingdom of Mysore. It is one of the most visited monuments in India after the Taj Mahal. The current structure was completed in 1912 after the old wooden palace burned down in 1897. It is built in the Indo-Saracenic style incorporating Hindu, Muslim, Rajput and Gothic elements. Every Sunday evening and during the Dasara festival, the palace is illuminated by 97,000 light bulbs creating one of the most spectacular sights in India.', highlights:['97,000 light bulbs illuminate the palace every Sunday — visible from miles away', 'The Dasara exhibition inside the palace during October is the grandest in India', 'The golden howdah (elephant throne) weighs 750 kg and is solid gold', 'The Durbar Hall has massive paintings depicting the Dasara procession', 'The royal family still lives in part of the palace complex'], tips:'Visit on a Sunday evening to see the spectacular illumination with 97,000 bulbs. During Dasara in October the experience is unparalleled — the entire city celebrates. Hire an audio guide to understand the rich royal history.' },
  19: { built:'17th century CE', dynasty:'Ladakhi Royals', builder:'King Sengge Namgyal', type:'Palace', entry:'₹50', timings:'7:00 AM – 1:00 PM (All days)', fullDesc:'Leh Palace is a former royal palace located in Leh, Ladakh. It was built in the 17th century by King Sengge Namgyal and is modelled after the Potala Palace in Lhasa, Tibet. The nine-story palace rises dramatically above the ancient Silk Road town of Leh at an altitude of 3,500 metres, overlooking the Indus Valley. Although partially in ruins, it still dominates the Leh skyline. The palace houses a museum with rare Thangkas, costumes, and royal artefacts.', highlights:['Stands at 3,500 metres above sea level — one of the highest palaces in the world', 'Nine stories tall and visible from most of the Leh valley', 'Modelled directly on the Potala Palace in Lhasa, Tibet', 'The top floor offers stunning 360° views of the Ladakh ranges', 'The palace was occupied until the 1940s when the royal family moved to Stok'], tips:'Combine a visit with the Namgyal Tsemo monastery above and the Leh market below. The views from the roof at sunset over the Leh valley and Indus River are extraordinary. Acclimatise for 2 days before exploring — altitude is significant.' },
  20: { built:'1559 CE (started)', dynasty:'Sisodia Rajputs', builder:'Maharana Udai Singh II', type:'Palace Complex', entry:'₹30 (Indian) / ₹240 (Foreign)', timings:'9:30 AM – 5:30 PM (All days)', fullDesc:'City Palace, Udaipur is a palace complex situated on the east bank of Lake Pichola in Udaipur, Rajasthan. Built over a period of nearly 400 years, starting in 1559, it is the largest royal complex in Rajasthan. The complex contains 11 palaces, 4 main gates, and numerous courtyards and gardens. The architecture is a fusion of Rajasthani and Mughal styles. The Zenana Mahal (women\'s quarters) has been converted into a museum, while the Shiv Niwas and Fateh Prakash palaces are heritage hotels.', highlights:['Houses the world\'s largest royal household — the Mewar royal family still lives here', 'The view of the white City Palace from Lake Pichola is one of India\'s most iconic', 'The Crystal Gallery houses one of the world\'s finest collections of Osler crystal', 'The Mor Chowk (Peacock Courtyard) has spectacular mosaic peacocks in three seasons', 'The Sheesh Mahal here rivals any other Hall of Mirrors in India'], tips:'Take a boat ride on Lake Pichola first to see the palace from the water — the view is extraordinary. The museum within is extensive. Sunset from the rooftop Sunset Terrace restaurant is one of the best experiences in Rajasthan.' },
  21: { built:'1591 CE', dynasty:'Qutb Shahi', builder:'Muhammad Quli Qutb Shah', type:'Mosque and Monument', entry:'₹25 (Indian) / ₹300 (Foreign)', timings:'9:30 AM – 5:30 PM (All days)', fullDesc:'The Charminar is a monument and mosque located in Hyderabad. Built in 1591 by Muhammad Quli Qutb Shah, the fifth ruler of the Qutb Shahi dynasty, it was constructed to commemorate the end of a deadly plague that had ravaged the city. The structure has four grand arches facing the four fundamental directions, each topped by a minaret. The name means "Four Minarets" in Urdu. It is considered the Arc de Triomphe of Hyderabad and is the symbol of the city, appearing on many brands and products from Hyderabad.', highlights:['Built to commemorate the end of a deadly plague epidemic in 1591', 'The four minarets are 56 metres tall and open to the public for views', 'A mosque on the top floor is still active — over 400 years old', 'The surrounding Laad Bazaar is famous for bangles since the Qutb Shahi era', 'The structure was the geographic centre of the original city of Hyderabad'], tips:'Visit in the evening when the monument is illuminated. The narrow lanes of Laad Bazaar and Chudi Bazaar around it sell stunning bangles and pearls. The biryani restaurants in the old city nearby are legendary — do not miss them.' },
  22: { built:'5th–8th century CE', dynasty:'Gupta / Rashtrakuta', builder:'Multiple rulers', type:'Cave Temple', entry:'₹40 (Indian + boat) / ₹600 (Foreign + boat)', timings:'9:00 AM – 5:30 PM (Closed Monday)', fullDesc:'The Elephanta Caves are a collection of cave temples located on Elephanta Island in Mumbai Harbour. The island contains two groups of caves — the main group of five Hindu caves and a smaller group of two Buddhist caves. The Hindu caves contain rock-cut sculptures dating from the 5th to 8th century CE. The chief attraction is the 6-metre Maheshamurti — a majestic three-headed bust of Shiva representing his three aspects: creator, preserver and destroyer. The island is accessible only by boat from the Gateway of India.', highlights:['The Trimurti sculpture — three-faced 6-metre bust of Shiva — is one of the finest sculptures in the world', 'The island was named "Elephanta" by Portuguese colonisers after a stone elephant they found', 'The site was used as target practice by Portuguese and Mughal forces — many sculptures are damaged', 'The caves were carved entirely by hand using only chisels and hammers', 'A local Elephanta Festival of classical dance is held here annually'], tips:'Take the ferry from Gateway of India — the 1-hour boat ride is part of the experience. Allow 2–3 hours to explore all caves. Carry water and snacks. The toy train on the island is a fun way to get to the caves from the jetty.' },
  23: { built:'3rd century BCE', dynasty:'Mauryan Empire', builder:'Emperor Ashoka', type:'Buddhist Stupa', entry:'₹40 (Indian) / ₹600 (Foreign)', timings:'Sunrise to Sunset (All days)', fullDesc:'The Sanchi Stupa is a Buddhist complex in Sanchi, Madhya Pradesh. The Great Stupa at Sanchi is one of the oldest stone structures in India and was originally commissioned by the Maurya emperor Ashoka the Great in the 3rd century BCE. It contains relics of the Buddha. The complex also contains several other stupas, temples, monasteries and pillars from various periods. The four elaborate carved gateways (toranas) at the cardinal directions are masterpieces of ancient Indian art depicting the life of Buddha.', highlights:['The torana gateways are some of the earliest surviving stone carvings in India', 'Emperor Ashoka built it to enshrine relics of the Buddha after his conversion to Buddhism', 'The carved scenes are some of the earliest depictions of the Buddha\'s life in art', 'The Ashoka Pillar at Sanchi inspired India\'s national emblem — the Lion Capital', 'The site was forgotten for 700 years before being rediscovered by General Taylor in 1818'], tips:'The site is best visited in early morning or late afternoon. The Archaeological Museum next to the stupa houses original sculptures recovered from the site. Sanchi is 46 km from Bhopal — an easy day trip.' },
  24: { built:'1986 CE', dynasty:'Bahá\'í Faith', builder:'Fariborz Sahba (Architect)', type:'House of Worship', entry:'Free', timings:'9:00 AM – 7:00 PM (Closed Monday)', fullDesc:'The Lotus Temple is a Bahá\'í House of Worship in New Delhi. Completed in 1986, it is notable for its flowerlike shape and is one of the most visited buildings in the world, having received over 100 million visitors. The free-standing structure consists of 27 pure white marble petals arranged in clusters of three to form nine sides. No religious ceremonies, rituals, or sermons are conducted here — it is open to people of all faiths for quiet prayer and meditation. The building was designed by Iranian-Canadian architect Fariborz Sahba.', highlights:['27 white marble-clad "petals" are arranged in three clusters of nine', 'Received over 100 million visitors — one of the most visited buildings in the world', 'Open to all faiths — no rituals, ceremonies, or idols inside', 'The nine pools surrounding the building represent lotus leaves floating on water', 'Won numerous architectural awards including the Glob Award for outstanding architectural achievement'], tips:'Go early morning or late afternoon to avoid massive queues — queues can be 2 hours long on weekends. No photography inside the prayer hall. The surrounding gardens are beautiful. Silence must be maintained inside.' },
  25: { built:'1887 CE', dynasty:'Wadiyar Dynasty', builder:'Chamarajendra Wadiyar X', type:'Palace', entry:'₹230 (Indian) / ₹460 (Foreign)', timings:'10:00 AM – 5:30 PM (All days)', fullDesc:'Bangalore Palace was built in 1887 and is modelled on Windsor Castle in England with Tudor-style arches, fortified towers, and wood-panelled interiors. The palace is spread over 45,000 sq ft and is still owned by the Wadiyar royal family of Mysore. The interior is adorned with floral motifs, paintings by Raja Ravi Varma, oil paintings, photographs and artefacts from the royal household. The palace grounds have been used to host major concerts including Rolling Stones and Elton John.', highlights:['Modelled on Windsor Castle in England — completed in 1878', 'The interior has paintings by the legendary Indian artist Raja Ravi Varma', 'Still privately owned by the Mysore royal family', 'Rolling Stones, Dire Straits and other international acts have performed on the grounds', 'The palace has a secret underground tunnel leading to Tipu Sultan\'s summer palace'], tips:'The audio guide is excellent and tells stories about the royal family. The palace is less visited than Mysore Palace making it a peaceful experience. The gardens are lovely for a stroll.' },
  26: { built:'1920s CE', dynasty:'British Raj', builder:'Various', type:'Promenade', entry:'Free', timings:'24 Hours (All days)', fullDesc:'Marine Drive is a 3.6-kilometre-long boulevard in South Mumbai alongside the Arabian Sea. The promenade curves from Nariman Point to Babulnath and is lined with Art Deco buildings on one side and the sea on the other. When seen at night from above, the street lights along the curve resemble a diamond necklace, giving it the name "Queen\'s Necklace." It is the most beloved public space in Mumbai — a place where all of the city comes to walk, eat, watch sunsets, and breathe.', highlights:['The Art Deco buildings along Marine Drive are a UNESCO World Heritage Site', 'The curved bay creates perfect waves for watching during monsoon — some of India\'s most dramatic', 'The Queen\'s Necklace name comes from the curved line of streetlights seen at night from Malabar Hill', 'Nariman Point at the southern tip was reclaimed from the sea in the 1960s', 'Every major Indian celebration — from cricket victories to New Year — draws lakhs here'], tips:'Visit at sunset and stay for the Queen\'s Necklace effect after dark. The bhel puri and corn vendors along the promenade are a Mumbai institution. The walk from Nariman Point to Chowpatty Beach is one of the great urban walks in Asia.' },
  27: { built:'Natural', dynasty:'—', builder:'Nature', type:'Lake', entry:'₹100 (Shikara)', timings:'All day', fullDesc:'Dal Lake is a urban lake in Srinagar, the summer capital of Jammu and Kashmir. It is integral to tourism and is known for its floating gardens (locally called "Rad"), the shikaras (wooden boats), and the iconic houseboats that line the shores. The lake is fed by the Telbal nallah stream and natural springs, and has an area of 18 sq km. It is surrounded by mountains and historic Mughal gardens. Often called the "Jewel of Kashmir" or "Srinagar\'s Jewel", it has inspired poets, painters, and emperors for centuries.', highlights:['Floating gardens called "Rads" grow vegetables on the lake surface', 'The floating market opens at 5 AM where vegetable vendors sell from shikaras', 'Mughal emperor Jahangir reportedly said "If there is a paradise on earth, it is this"', 'Over 50,000 people live on and around the lake in houseboats and floating villages', 'Skiing is possible on the nearby Gulmarg slopes which are visible from the lake'], tips:'Stay on a traditional houseboat for the authentic Dal Lake experience. Take a shikara at sunrise for the floating vegetable market. Visit Nishat and Shalimar Mughal Gardens on the banks. Autumn (October) is the most beautiful season with golden chinar trees.' },
  28: { built:'Natural', dynasty:'—', builder:'Nature', type:'Lake', entry:'₹Free (permit required)', timings:'Seasonal (May–October)', fullDesc:'Pangong Lake is a high-altitude lake in the Himalayas situated at a height of 4,350 metres. At 134 km long, it extends from India to China with about 60% in Chinese territory. The lake is known for its extraordinary shifting colours — deep blue, azure, green, and turquoise — that change throughout the day depending on the sunlight and season. The lake is a high-altitude saline lake and is not suitable for supporting aquatic life. It became internationally famous after the film "3 Idiots" was shot here.', highlights:['The lake turns vivid blue, green and turquoise at different times of day', 'About 60% of the lake falls in Chinese territory', 'There is no aquatic life as the water is brackish (salty)', 'The lake freezes solid in winter and locals conduct cricket matches on the ice', '"3 Idiots" climax scene was shot here — it now receives thousands of visitors annually'], tips:'Requires an Inner Line Permit from Leh. The road from Leh takes 5 hours and is spectacular. Acclimatise in Leh for 2 days first — altitude sickness is common. Stay in a tent camp by the lake for the sunrise which is extraordinary.' },
  29: { built:'Natural', dynasty:'—', builder:'Nature', type:'National Park', entry:'₹150 (Indian) / ₹600 (Foreign)', timings:'Seasonal (June–October)', fullDesc:'The Valley of Flowers National Park is an Indian national park and UNESCO World Heritage Site located in the Chamoli district of Uttarakhand in the Himalayan region. The high-altitude Himalayan valley is renowned for its meadows of endemic alpine flowers and the outstanding natural beauty. The valley was discovered by mountaineer Frank Smythe in 1931 after he accidentally descended into it. It is home to rare and endangered animals including the Asiatic black bear, snow leopard, and brown bear.', highlights:['Over 600 species of wild alpine flowers bloom here during the monsoon season', 'Home to the extremely rare snow leopard and Himalayan brown bear', 'Discovered accidentally by British mountaineer Frank Smythe in 1931', 'The valley floor is covered in flowers visible only from July to September', 'Nanda Devi — India\'s second highest peak — is visible from the valley'], tips:'Trek season is July to mid-September when flowers are in bloom. The trek from Govindghat is 17 km. Combine with the Hemkund Sahib Gurudwara trek nearby. No camping is allowed inside the valley — stay in Ghangaria village.' },
  30: { built:'Natural', dynasty:'—', builder:'Nature', type:'Tea Plantation', entry:'Free (plantation tours ₹200)', timings:'All year (Best Oct–Mar)', fullDesc:'Munnar is a hill station in the Idukki district of Kerala, located at the confluence of three mountain streams — Mudrapuzha, Nallathanni, and Kundala. It is situated at an altitude of 1,600 metres in the Western Ghats and is known for its vast tea plantations, rolling hills, and cool climate. The Kanan Devan Hills Plantations Company (KDHP) manages most of the tea estates. The rare Neelakurinji flower, which blooms once every 12 years (next in 2030), covers the hillsides in purple when it blooms.', highlights:['Neelakurinji flower blooms only once every 12 years covering hills in purple', 'The Tata Tea Museum explains the fascinating history of tea cultivation in the region', 'Eravikulam National Park nearby protects the endangered Nilgiri Tahr mountain goat', 'At peak, tea pickers harvest by hand with extraordinary speed and skill', 'The highest peak in peninsular India — Anamudi (2,695m) — is here'], tips:'The drive up from Coimbatore or Kochi on winding mountain roads through tea estates is itself spectacular. Visit the KDHP Tea Museum. Sunrise from Top Station is world-class. Eravikulam National Park must be booked in advance.' },
  31: { built:'Natural', dynasty:'—', builder:'Nature', type:'Backwater', entry:'₹200–₹15,000 (Houseboat)', timings:'All year (Best Oct–Feb)', fullDesc:'Alleppey (Alappuzha) is known for its extensive network of canals, backwaters, beaches and lagoons. The backwaters of Kerala are a network of interconnected canals, rivers, lakes and inlets formed by more than 900 km of waterways. The traditional rice-barge houseboats called "Kettuvallam" have been converted into luxury floating hotels. The Nehru Trophy Boat Race held here in August is one of Kerala\'s most iconic events, featuring traditional snake boats (Chundan vallams) racing on Punnamada Lake.', highlights:['Over 900 km of interconnected waterways form the backwater network', 'Traditional "Kettuvallam" houseboats were originally used to transport rice and spices', 'The Nehru Trophy Snake Boat Race in August draws thousands of spectators', 'The backwaters are home to freshwater fish, kingfishers, and water birds', 'Kumarakom Bird Sanctuary nearby hosts migratory birds including Siberian cranes'], tips:'Overnight houseboat stays are the definitive experience — book a premium houseboat for Kerala cuisine and sunset views. The canoe rides through narrow village canals are more intimate than large houseboats. Visit between October and February.' },
  37: { built:'Natural', dynasty:'—', builder:'Nature', type:'National Park', entry:'₹200 (Indian) / ₹650 (Foreign)', timings:'Varies by season', fullDesc:'Kaziranga National Park is a UNESCO World Heritage Site in the Golaghat, Karbi Anglong and Nagaon districts of Assam. The park is home to the world\'s largest population of the Indian one-horned rhinoceros — about 2,400, representing 70% of the world\'s total. It also has one of the highest densities of tigers in any protected area worldwide. The park is declared a Tiger Reserve and hosts large breeding populations of elephants, wild water buffalo and swamp deer.', highlights:['Home to over 2,400 one-horned rhinos — 70% of the world\'s total population', 'Has the highest density of tigers in any protected area in the world', 'The park is also a key habitat for Asian elephants, wild buffalo and swamp deer', 'Over 480 species of birds have been recorded — a birdwatcher\'s paradise', 'Central Highlands have the most rhino sightings'], tips:'Visit between November and April. Jeep safaris (morning) and elephant safaris (morning) give different perspectives. The Western range has the best rhino concentration. Book accommodation in Kohora village well in advance for peak season.' },
  51: { built:'1681 CE', dynasty:'Tibetan Buddhist', builder:'Merak Lama Lodre Gyatso', type:'Monastery', entry:'₹50', timings:'6:00 AM – 7:00 PM', fullDesc:'Tawang Monastery, or Galden Namgey Lhatse (Celestial Paradise on a Clear Night), is the largest monastery in India and second largest in Asia, located in the Tawang district of Arunachal Pradesh at an altitude of 3,048 metres. It was founded by Merak Lama Lodre Gyatso in 1681 and belongs to the Gelugpa sect of Buddhism. The monastery is home to about 450 monks and houses a 8-metre tall golden Buddha statue, and an extensive library of rare Buddhist scriptures.', highlights:['Second largest Buddhist monastery in Asia — covers an area of 400 sq metres', 'Houses a gold-gilded 8-metre tall statue of the Shakyamuni Buddha', 'An extensive library has over 400 manuscripts of rare Buddhist scriptures', 'The 6th Dalai Lama was born in Tawang in 1683', 'The monastery overlooks the Tawang valley and the glacier below at an altitude of 3,000m'], tips:'Tawang requires an Inner Line Permit. The drive from Guwahati via Bomdila takes 2 days and is spectacular. Visit the Tawang War Memorial nearby. The monastery is most atmospheric during the Torgya Festival in January.' },
  60: { built:'2005 CE', dynasty:'BAPS Swaminarayan', builder:'Pramukh Swami Maharaj', type:'Temple Complex', entry:'₹170 (Indian) / ₹400 (Foreign)', timings:'9:30 AM – 8:00 PM (Closed Monday)', fullDesc:'Akshardham Temple in New Delhi is one of the world\'s largest Hindu temples, completed in 2005. It is made of 6,000 tonnes of pink sandstone from Rajasthan and white marble from Italy with no steel used in its construction. Over 11,000 artisans and 3,000 volunteers worked on it. The complex includes a monument, exhibitions, a water show, a thematic garden, a boat ride, and a large-screen film. It holds records in the Guinness Book of World Records for the world\'s largest comprehensive Hindu temple.', highlights:['No steel was used — entirely built from pink Rajasthani sandstone and Italian marble', 'Over 20,000 carved figurines of sadhus, devotees, deities and animals decorate it', 'The Sahaj Anand Water Show at night is one of the best cultural shows in India', 'The Neelkanth boat ride inside recreates ancient India\'s flora and fauna', 'Holds 5 Guinness World Records including world\'s largest Hindu temple complex'], tips:'Allow a full day — the exhibitions inside are extensive and excellent. The water show at 7:30 PM is spectacular and tickets sell out. No photography inside the main monument. Leave electronics at designated counters.' },
  61: { built:'2500+ years ago', dynasty:'Various including Nayaks', builder:'Multiple rulers', type:'Hindu Temple', entry:'Free (₹50 for special darshan)', timings:'5:00 AM – 9:30 PM (All days)', fullDesc:'Meenakshi Amman Temple is a historic Hindu temple located on the southern bank of the Vaigai River in the temple city of Madurai. It is dedicated to the goddess Meenakshi, a form of Parvati, and her consort Sundareswarar, a form of Shiva. It has 14 towering gopurams (gateway towers) decorated with thousands of colourful sculptures. The tallest tower is 52 metres. The temple covers 14 acres and is one of the largest temples in India, receiving 15,000 to 20,000 visitors daily and up to 25,000 during festivals.', highlights:['14 soaring gateway towers (gopurams) decorated with over 33,000 sculptures', 'The Hall of 1,000 Pillars has 985 pillars each with unique carvings — no two are alike', 'The Golden Lotus Tank inside the temple is said to test the merit of new literary works', 'The temple has never closed in 3,000 years of recorded history', 'Over 30,000 visitors come daily during the famous Chittirai Festival'], tips:'Go at dawn when the temple opens for the most peaceful experience. The musical pillars (Sruthi Mandapam) produce different musical notes when struck — ask a priest to demonstrate. The night puja (8 PM) is spectacular when the deity is taken in procession.' },
  62: { built:'1010 CE', dynasty:'Chola Dynasty', builder:'Emperor Raja Raja Chola I', type:'Temple', entry:'Free', timings:'6:00 AM – 12:30 PM, 4:00 PM – 8:30 PM', fullDesc:'The Brihadeeswarar Temple, also called the Big Temple, is a Hindu temple dedicated to Shiva located in Thanjavur, Tamil Nadu. Built by Emperor Raja Raja Chola I and completed in 1010 CE, it is one of the largest temples in India and an exemplary example of Dravidian architecture. The vimana (tower over the sanctum) is 66 metres tall and its shadow never falls on the ground at noon due to the precise astronomical orientation. The capstone alone weighs 80 tonnes and was placed using an inclined ramp believed to be 6 km long.', highlights:['The 80-tonne capstone was lifted using a 6-km-long inclined ramp', 'The vimana casts no shadow at noon on any day of the year', 'Built entirely of granite — not a single stone quarried within 100 km radius', 'The Nandi bull in the courtyard is carved from a single rock and is 2 metres tall', 'Over 81 figures of Shiva in different dance poses are carved on the base of the tower'], tips:'Visit the Thanjavur Palace and Art Gallery nearby which houses the world\'s finest Chola bronze collection. The temple is the centrepiece of the Gangaikondacholapuram circuit. Best visited early morning or late evening when lit.' },
