        <div style="background:var(--bg3);border:1px solid var(--border2);border-radius:12px;padding:2rem;display:flex;flex-direction:column;align-items:center;gap:1rem;text-align:center;">
          <div style="font-size:3rem;">🏛</div>
          <p id="mdetail3DName" style="font-size:14px;font-weight:600;color:var(--text);"></p>
          <p style="font-size:12px;color:var(--text2);line-height:1.6;max-width:360px;">View a fully interactive 3D model — rotate 360°, zoom in, and explore every architectural detail.</p>
          <a id="mdetail3DLink" href="#" target="_blank" rel="noopener" style="display:inline-flex;align-items:center;gap:8px;padding:11px 28px;background:var(--gold);border:none;border-radius:8px;color:#0d1117;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;transition:background 0.2s,transform 0.15s;"
            onmouseover="this.style.background='var(--gold2)';this.style.transform='translateY(-2px)'"
            onmouseout="this.style.background='var(--gold)';this.style.transform='translateY(0)'">
            🔗 View 3D Model on Sketchfab
          </a>
          <p style="font-size:10px;color:var(--text3);">Opens in a new tab · Free · No login required</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ═══════════════ AUTH MODAL ═══════════════ -->
<div class="modal-overlay" id="authModal" onclick="if(event.target===this)closeAuthModal()">
  <div class="modal-box">
    <button class="modal-close" onclick="closeAuthModal()">✕</button>
    <p class="modal-title">Welcome Back 🙏</p>
    <p class="modal-sub">Sign in to save itineraries, track your heritage journey, and unlock AI features.</p>
    <div class="modal-field">
      <label>Your Name</label>
      <input type="text" id="authName" placeholder="Arjun Sharma" onkeydown="if(event.key==='Enter')document.getElementById('authEmail').focus()">
    </div>
    <div class="modal-field">
      <label>Email Address</label>
      <input type="email" id="authEmail" placeholder="arjun@example.com" onkeydown="if(event.key==='Enter')submitAuth()">
    </div>
    <p class="modal-error" id="authError"></p>
    <button class="modal-btn" onclick="submitAuth()">Continue →</button>
    <p class="modal-note">No password needed. Your data stays on your device.</p>
  </div>
</div>

<!-- ═══════════════ TOAST ═══════════════ -->
<div id="wthToast"></div>

</body>
</html>
