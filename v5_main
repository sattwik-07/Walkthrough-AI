  // Animate loading steps
  let s = 0;
  const si = setInterval(() => {
    if (s < pfLoadSteps.length) document.getElementById('pfStep').textContent = pfLoadSteps[s++];
  }, 400);

  try {
    const itinerary = await callPlanner({
      destination: destLabel,
      days,
      budget,
      interests,
      style,
      travellers
    });
    clearInterval(si);
    document.getElementById('pfLoading').classList.remove('visible');
    lastItinData = { dest: destLabel, days, data: itinerary };
