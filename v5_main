  } catch (err) {
    clearInterval(si);
    document.getElementById('pfLoading').classList.remove('visible');
    document.getElementById('pfEmpty').style.display = '';
    showToast('⚠ Could not generate itinerary. Please try again.');
  } finally {
    btn.disabled = false;
    document.getElementById('pfGenLabel').textContent = 'Regenerate Itinerary';
    document.getElementById('pfGenIcon').textContent = '↺';
  }
}

function pfBuildItinFromAI(data, destLabel, totalDays, budget) {
  const budgetCost = { budget:'₹4,200', mid:'₹11,500', luxury:'₹32,000' };
  const estimatedCost = data.budgetPerDay || budgetCost[budget] || '₹11,500';

  document.getElementById('pfBadges').innerHTML = `
    <span class="pitin-badge-gold">${totalDays} Days</span>
    <span class="pitin-badge-outline">${budget === 'mid' ? 'Mid' : budget === 'luxury' ? 'Luxury' : 'Budget'} Budget</span>
    <span class="pitin-badge-outline">✦ AI Generated</span>
  `;
  document.getElementById('pfItinTitle').textContent = `${data.emoji || '🏛'} ${data.title || destLabel + ' Heritage Journey'}`;
  document.getElementById('pfItinSub').textContent = data.tagline || `A curated ${totalDays}-day heritage experience`;
  document.getElementById('pfStats').innerHTML = `
    <div><span class="pitin-stat-num">${totalDays}</span><span class="pitin-stat-label">Days</span></div>
    <div><span class="pitin-stat-num">${totalDays * 3}</span><span class="pitin-stat-label">Experiences</span></div>
    <div><span class="pitin-stat-num">${data.monuments || 6}</span><span class="pitin-stat-label">Monuments</span></div>
    <div><span class="pitin-stat-num">${estimatedCost}</span><span class="pitin-stat-label">Est./Day</span></div>
  `;

  const container = document.getElementById('pfDays');
  container.innerHTML = '';
  const start = new Date(); start.setDate(start.getDate() + 7);

  const dayKeys = Object.keys(data.days);
  for (let i = 0; i < totalDays; i++) {
    const key = dayKeys[i % dayKeys.length];
    const d = data.days[key];
    const dt = new Date(start); dt.setDate(dt.getDate() + i);
    const ds = dt.toLocaleDateString('en-IN', { weekday:'short', day:'numeric', month:'short' });

    const card = document.createElement('div');
    card.className = 'pitin-day';
    card.innerHTML = `
      <div class="pitin-day-hdr ${i===0?'open':''}" onclick="pfToggleDay(this)">
        <div class="pitin-day-left">
          <div class="pitin-day-circle">D${i+1}</div>
          <div>
            <div class="pitin-day-title">Day ${i+1} — ${d.title}</div>
            <div class="pitin-day-date">${ds}</div>
          </div>
        </div>
        <span class="pitin-chevron">▼</span>
      </div>
      <div class="pitin-day-body ${i===0?'open':''}">
        ${pfSlot('Morning','🌅','morning','7 AM',d.m,'#fcc419')}
        ${pfSlot('Afternoon','☀','afternoon','1 PM',d.a,'#d4a843')}
        ${pfSlot('Evening','🌙','evening','6 PM',d.e,'#818cf8')}
      </div>`;
    container.appendChild(card);
  }

  document.getElementById('pfItin').classList.add('visible');
  document.getElementById('pfItin').scrollIntoView({ behavior:'smooth', block:'start' });
