let mapInitialised = false;
const mapImgCache = {};
let leafletMap = null;
let leafletMarkers = {};
let activeMarker = null;

function openMapModal() {
  document.getElementById('mapModal').style.display = 'flex';
  document.body.style.overflow = 'hidden';
  if (!mapInitialised) {
    // Load Leaflet JS dynamically
    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.onload = () => { initLeafletMap(); buildMapList(); };
    document.head.appendChild(script);
    mapInitialised = true;
  }
}

function closeMapModal() {
  document.getElementById('mapModal').style.display = 'none';
  document.body.style.overflow = '';
}

function initLeafletMap() {
  // Init map centred on India
  leafletMap = L.map('leafletMap', { zoomControl: true }).setView([20.5937, 78.9629], 5);

  // CartoDB light tiles — free, no API key, no referer restrictions
  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
    attribution: '© OpenStreetMap © CARTO',
    subdomains: 'abcd',
    maxZoom: 19,
  }).addTo(leafletMap);

  // Add a marker for every monument with coords
  monuments.forEach(m => {
    const coord = mapCoords[m.id];
    if (!coord) return;

    const color = m.badge === 'unesco' ? '#1a6fc4' : '#d4a843';
    const icon = L.divIcon({
      className: '',
      html: `<div style="
        width:14px;height:14px;border-radius:50%;
        background:${color};border:2px solid rgba(255,255,255,0.7);
        box-shadow:0 0 6px ${color};cursor:pointer;
        transition:transform 0.2s;">
      </div>`,
      iconSize: [14, 14],
      iconAnchor: [7, 7],
    });

    const marker = L.marker([coord.lat, coord.lng], { icon })
      .addTo(leafletMap)
      .bindTooltip(`<strong>${m.name}</strong><br><span style="font-size:11px;color:#888">📍 ${m.location}</span>`, {
        direction: 'top', offset: [0, -8],
        className: 'leaflet-wth-tooltip'
      });

    marker.on('click', () => selectMapMonument(m));
    leafletMarkers[m.id] = marker;
  });

  // Fix map size after modal opens
  setTimeout(() => leafletMap.invalidateSize(), 300);
}

function buildMapList() {
  const list = document.getElementById('mapMonumentList');
  if (!list) return;
  list.innerHTML = '';
  monuments.forEach(m => {
    const item = document.createElement('div');
    item.className = 'map-list-item';
    item.setAttribute('data-name', m.name.toLowerCase());
    item.setAttribute('data-id', m.id);
    item.style.cssText = 'display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:8px;cursor:pointer;transition:all 0.15s;margin-bottom:2px;border-left:2px solid transparent;';
    item.innerHTML = `
      <span style="width:8px;height:8px;border-radius:50%;flex-shrink:0;background:${m.badge==='unesco'?'#1a6fc4':'var(--gold)'}"></span>
      <div style="min-width:0;flex:1;">
        <div style="font-size:11px;color:var(--text);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${m.name}</div>
        <div style="font-size:9px;color:var(--text3);">${m.location.split(',')[0]}</div>
      </div>
      <span style="font-size:9px;color:var(--gold);">★${m.rating}</span>`;
    item.onmouseover = () => { if(item.getAttribute('data-id') != (activeMarker?.mId||'')) item.style.background = 'var(--bg3)'; };
    item.onmouseout  = () => { if(item.getAttribute('data-id') != (activeMarker?.mId||'')) item.style.background = 'transparent'; };
    item.onclick = () => selectMapMonument(m);
    list.appendChild(item);
  });
}

function filterMapList(q) {
  document.querySelectorAll('.map-list-item').forEach(el => {
    el.style.display = el.getAttribute('data-name').includes(q.toLowerCase()) ? 'flex' : 'none';
  });
}

function selectMapMonument(m) {
  const coord = mapCoords[m.id];

  // Pan & zoom map to monument
  if (leafletMap && coord) {
    leafletMap.flyTo([coord.lat, coord.lng], 13, { duration: 1.2 });
    if (leafletMarkers[m.id]) leafletMarkers[m.id].openTooltip();
  }

  // Show info card
  const card = document.getElementById('mapInfoCard');
  document.getElementById('mapInfoName').textContent   = m.name;
  document.getElementById('mapInfoLoc').textContent    = '📍 ' + m.location;
  document.getElementById('mapInfoRating').textContent = '★ ' + m.rating + ' / 5.0';
  document.getElementById('mapInfoBtn').onclick = () => { closeMapModal(); openMonument(m.id); };
  card.style.display = 'block';

  // Load Wikipedia image
  const img = document.getElementById('mapInfoImg');
  img.src = '';
  if (mapImgCache[m.id]) { img.src = mapImgCache[m.id]; }
  else if (m.wiki) {
    fetch(`https://en.wikipedia.org/api/rest_v1/page/summary/${m.wiki}`, { headers: { Accept: 'application/json' } })
      .then(r => r.json()).then(data => {
        const url = data?.thumbnail?.source;
        if (url) { mapImgCache[m.id] = url.replace(/\/\d+px-/, '/120px-'); img.src = mapImgCache[m.id]; }
      }).catch(() => {});
  }

  // Highlight in list
  document.querySelectorAll('.map-list-item').forEach(el => {
    const isActive = el.getAttribute('data-id') == m.id;
    el.style.background    = isActive ? 'var(--gold-dim)' : 'transparent';
    el.style.borderLeft    = isActive ? '2px solid var(--gold)' : '2px solid transparent';
  });

  // Scroll item into view
  const activeEl = document.querySelector(`.map-list-item[data-id="${m.id}"]`);
  if (activeEl) activeEl.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
}

