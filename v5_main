// ─── API (relative URLs — works on any domain) ────────────────

async function callChat(messages) {
  const langInstruction = getLangInstruction();
  const res = await fetch('/api/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ messages, langInstruction })
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err.error || `${res.status}`);
  }
  const data = await res.json();
  return data.reply;
}

async function callPlanner(payload) {
  const res = await fetch('/api/planner', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  });
  if (!res.ok) {
    const err = await res.json().catch(() => ({}));
    throw new Error(err.error || `Server error ${res.status}`);
  }
  const data = await res.json();
  return data.itinerary;
}

// ─── AUTH MODAL ───────────────────────────────────────────────
function getUser() { try { return JSON.parse(localStorage.getItem('wth_user') || 'null'); } catch { return null; } }
function setUser(u) { localStorage.setItem('wth_user', JSON.stringify(u)); }

function openAuthModal() {
  const user = getUser();
  if (user) {
    // Already signed in — show profile/sign-out
    const confirmed = confirm(`Signed in as ${user.name} (${user.email})\n\nSign out?`);
    if (confirmed) { localStorage.removeItem('wth_user'); updateNavAuth(); }
    return;
  }
  document.getElementById('authModal').style.display = 'flex';
  document.getElementById('authEmail').focus();
}
function closeAuthModal() { document.getElementById('authModal').style.display = 'none'; }

function submitAuth() {
  const name  = document.getElementById('authName').value.trim();
  const email = document.getElementById('authEmail').value.trim();
  if (!name || !email || !email.includes('@')) {
    document.getElementById('authError').textContent = 'Please enter a valid name and email.';
    return;
  }
  setUser({ name, email, since: new Date().toISOString() });
  closeAuthModal();
  updateNavAuth();
  showToast(`Welcome, ${name}! 🙏`);
}

function updateNavAuth() {
  const user = getUser();
  const btn = document.getElementById('navSignInBtn');
  if (btn) btn.textContent = user ? `${user.name.split(' ')[0]} ▾` : 'Sign In';
}

// ─── TOAST ────────────────────────────────────────────────────
function showToast(msg, duration = 3000) {
  const t = document.getElementById('wthToast');
  t.textContent = msg;
  t.classList.add('visible');
  setTimeout(() => t.classList.remove('visible'), duration);
}

