  { id:8, name:"Hawa Mahal", location:"Jaipur, Rajasthan", tags:["Rajput","Palace","Pink City"], type:["fort"], img:"https://images.unsplash.com/photo-1477587458883-47145ed6979c?w=600&q=80", rating:4.6, desc:"The Palace of Winds — a five-story pyramidal façade with 953 small windows decorated with intricate latticework.", badge:"heritage" },
  { id:9, name:"Ajanta Caves", location:"Maharashtra", tags:["Buddhist","UNESCO","Cave"], type:["buddhist","unesco"], img:"https://images.unsplash.com/photo-1596568401847-8c1e9e7e3d79?w=600&q=80", rating:4.7, desc:"30 rock-cut Buddhist cave monuments dating from the 2nd century BCE, renowned for their extraordinary murals.", badge:"unesco" },
  { id:10, name:"Brihadeeswarar Temple", location:"Thanjavur, Tamil Nadu", tags:["Chola","UNESCO","Temple"], type:["temple","dravidian","unesco"], img:"https://images.unsplash.com/photo-1584138793498-4b1bca1d0c9e?w=600&q=80", rating:4.8, desc:"A masterpiece of Chola architecture, the 1000-year-old temple's vimana rises to 66 metres with a single capstone weighing 80 tonnes.", badge:"unesco" },
];

let currentFilter = 'all';
let currentSort = 'default';
let filtered = [...monuments];

function renderMonuments() {
  const grid = document.getElementById('monumentsGrid');
  document.getElementById('countLabel').textContent = filtered.length;

  grid.innerHTML = filtered.map((m, i) => `
    <div class="monument-card" style="animation-delay:${i*0.06}s" onclick="openMonument(${m.id})">
      <div class="card-img">
        <img src="${m.img}" alt="${m.name}" loading="lazy">
        <span class="card-badge badge-${m.badge}">${m.badge === 'unesco' ? 'UNESCO' : 'Heritage'}</span>
        <button class="card-save" onclick="event.stopPropagation();this.textContent=this.textContent==='🔖'?'🔖':'🔖';" title="Save">🔖</button>
        <div class="card-overlay"></div>
        <div class="card-location">📍 ${m.location}</div>
      </div>
      <div class="card-body">
        <div class="card-tags">${m.tags.map(t=>`<span class="card-tag">${t}</span>`).join('')}</div>
        <h3 class="card-name">${m.name}</h3>
        <p class="card-desc">${m.desc}</p>
        <div class="card-footer">
          <div class="card-rating"><span class="star">★</span> ${m.rating} / 5.0</div>
          <span class="card-cta">Explore →</span>
        </div>
      </div>
    </div>
  `).join('');
}

function setFilter(el, f) {
  currentFilter = f;
  document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  applyFilters();
}

function filterMonuments() {
  applyFilters();
}

function applyFilters() {
  const query = document.getElementById('searchInput').value.toLowerCase();
  filtered = monuments.filter(m => {
    const matchQuery = !query || m.name.toLowerCase().includes(query) || m.location.toLowerCase().includes(query) || m.tags.some(t => t.toLowerCase().includes(query));
    const matchFilter = currentFilter === 'all' || m.type.includes(currentFilter);
    return matchQuery && matchFilter;
  });
  sortMonuments(currentSort);
  renderMonuments();
}

function sortMonuments(val) {
  currentSort = val;
  if (val === 'name') filtered.sort((a,b) => a.name.localeCompare(b.name));
  else if (val === 'rating') filtered.sort((a,b) => b.rating - a.rating);
  else if (val === 'era') filtered.sort((a,b) => a.id - b.id);
  else filtered.sort((a,b) => a.id - b.id);
  renderMonuments();
}

function setView(btn, view) {
  document.querySelectorAll('.view-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const grid = document.getElementById('monumentsGrid');
  if (view === 'list') {
    grid.style.gridTemplateColumns = '1fr';
  } else {
    grid.style.gridTemplateColumns = 'repeat(auto-fill, minmax(320px, 1fr))';
  }
}

function openMonument(id) {
  const m = monuments.find(x => x.id === id);
  alert(`🏛 ${m.name}\n\n📍 ${m.location}\n⭐ ${m.rating}/5.0\n\n${m.desc}`);
}

// ─── CHAT ───
const aiResponses = {
  default: "That's a fascinating question! India's heritage spans over 5,000 years. Could you be more specific about which monument or era you'd like to explore?",
  "taj mahal": "The Taj Mahal in Agra is a UNESCO World Heritage Site and one of the Seven Wonders of the World. Built by Shah Jahan (1632–1653) in memory of his wife Mumtaz Mahal, it took 22 years and 20,000 artisans. The white marble changes color throughout the day — pinkish at dawn, brilliant white at noon, and golden at moonlight. Best time to visit: October to March, arriving before sunrise. ✨",
  "red fort": "The Red Fort (Lal Qila) in Delhi was the main residence of Mughal emperors from 1648 to 1857. Built by Shah Jahan, it covers 254 acres and is surrounded by a 2.5 km moat. Every year on Independence Day, India's Prime Minister hoists the national flag here. It's a UNESCO World Heritage Site since 2007. 🏰",
  "rajasthan": "Rajasthan is India's largest state by area and home to some of its most spectacular forts and palaces. The 'Land of Kings' has Jaipur (Hawa Mahal, Amber Fort), Jodhpur (Mehrangarh Fort), Udaipur (City Palace), and Jaisalmer (the golden sandstone fort). The best time to visit is October to March. 🌅",
  "best time": "The best time to visit most Indian monuments is October to March when weather is cool and pleasant. Avoid May-June (extreme heat) and July-September (monsoon). Early mornings offer golden light for photography and fewer crowds. Most ASI monuments are open from 6 AM to 6 PM. 🌤",
};

function sendChat() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;

  const msgs = document.getElementById('chatMessages');

  // User message
  const userDiv = document.createElement('div');
  userDiv.className = 'msg msg-user';
  userDiv.textContent = msg;
  msgs.appendChild(userDiv);
  input.value = '';

  // Typing indicator
  const typing = document.createElement('div');
  typing.className = 'msg msg-ai';
  typing.textContent = '...';
  msgs.appendChild(typing);
  msgs.scrollTop = msgs.scrollHeight;

  setTimeout(() => {
    const lower = msg.toLowerCase();
    let response = aiResponses.default;
    for (const [key, val] of Object.entries(aiResponses)) {
      if (key !== 'default' && lower.includes(key)) { response = val; break; }
    }
    typing.textContent = response;
    msgs.scrollTop = msgs.scrollHeight;
  }, 1200);
}

// ─── PARTICLES ───
(function spawnParticles() {
  const container = document.getElementById('particles');
  if (!container) return;
  for (let i = 0; i < 20; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.style.left = Math.random() * 100 + '%';
    p.style.bottom = '-10px';
    p.style.animationDuration = (8 + Math.random() * 12) + 's';
    p.style.animationDelay = (Math.random() * 10) + 's';
    p.style.width = p.style.height = (1 + Math.random() * 3) + 'px';
    container.appendChild(p);
  }
})();

// ─── INIT ───
renderMonuments();
</script>
