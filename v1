<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Walk Through History — India's Heritage</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Cormorant+Garamond:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d1117;
    --bg2: #13181f;
    --bg3: #1a2130;
    --gold: #d4a843;
    --gold2: #f0c96a;
    --gold-dim: rgba(212,168,67,0.15);
    --text: #e8e0d4;
    --text2: #9a9080;
    --text3: #6a6055;
    --border: rgba(212,168,67,0.18);
    --border2: rgba(255,255,255,0.07);
    --card: #161c26;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 3px; }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; gap: 2rem;
    padding: 0 3rem;
    height: 68px;
    background: rgba(13,17,23,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border2);
  }

  .nav-logo {
    display: flex; align-items: center; gap: 10px;
    text-decoration: none; margin-right: auto;
  }

  .nav-logo-icon {
    width: 38px; height: 38px;
    background: var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }

  .nav-logo-text { line-height: 1.1; }
  .nav-logo-text strong { display: block; font-family: 'Playfair Display', serif; font-size: 15px; font-weight: 600; color: var(--text); }
  .nav-logo-text span { font-size: 11px; color: var(--gold); letter-spacing: 0.06em; }

  .nav-links { display: flex; gap: 0.25rem; }

  .nav-links a {
    text-decoration: none;
    color: var(--text2);
    font-size: 14px;
    padding: 6px 14px;
    border-radius: 6px;
    transition: color 0.2s, background 0.2s;
  }

  .nav-links a:hover, .nav-links a.active { color: var(--gold); }
  .nav-links a.active { background: var(--gold-dim); }

  .nav-actions { display: flex; align-items: center; gap: 10px; margin-left: auto; }

  .btn-outline {
    padding: 7px 18px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: transparent;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .btn-outline:hover { border-color: var(--gold); color: var(--gold); }

  .btn-gold {
    padding: 8px 20px;
    background: var(--gold);
    border: none;
    border-radius: 6px;
    color: #0d1117;
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-gold:hover { background: var(--gold2); transform: translateY(-1px); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 0%, rgba(212,168,67,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 60% 40% at 80% 80%, rgba(212,168,67,0.04) 0%, transparent 60%);
  }

  /* Decorative arch lines */
  .hero-arch {
    position: absolute;
    bottom: -80px; left: 50%; transform: translateX(-50%);
    width: 700px; height: 400px;
    border: 1px solid rgba(212,168,67,0.08);
    border-radius: 50% 50% 0 0;
    pointer-events: none;
  }
  .hero-arch:nth-child(2) { width: 900px; height: 500px; border-color: rgba(212,168,67,0.05); }
  .hero-arch:nth-child(3) { width: 1100px; height: 620px; border-color: rgba(212,168,67,0.03); }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.25rem;
    position: relative;
    display: flex; align-items: center; gap: 12px; justify-content: center;
  }

  .hero-eyebrow::before, .hero-eyebrow::after {
    content: '';
    display: inline-block;
    width: 32px; height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }

  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--text);
    margin-bottom: 1.5rem;
    position: relative;
  }

  .hero-title em {
    font-style: italic;
    color: var(--gold);
  }

  .hero-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.25rem;
    font-weight: 300;
    color: var(--text2);
    max-width: 540px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;
    margin-bottom: 4rem;
    position: relative;
  }

  .btn-hero-primary {
    padding: 13px 32px;
    background: var(--gold);
    border: none; border-radius: 6px;
    color: #0d1117;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px; font-weight: 500;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    letter-spacing: 0.02em;
  }
  .btn-hero-primary:hover { background: var(--gold2); transform: translateY(-2px); }

  .btn-hero-sec {
    padding: 13px 32px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, transform 0.15s;
  }
  .btn-hero-sec:hover { border-color: var(--gold); color: var(--gold); transform: translateY(-2px); }

  /* Floating particles */
  .particles {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden;
  }

  .particle {
    position: absolute;
    width: 3px; height: 3px;
    background: var(--gold);
    border-radius: 50%;
    opacity: 0;
    animation: float-up linear infinite;
  }

  @keyframes float-up {
    0% { opacity: 0; transform: translateY(0) scale(0); }
    10% { opacity: 0.6; transform: scale(1); }
    90% { opacity: 0.3; }
    100% { opacity: 0; transform: translateY(-120vh) scale(0.5); }
  }

  /* Stats strip */
  .hero-stats {
    display: flex; gap: 3rem; justify-content: center;
    position: relative;
  }

  .hero-stat { text-align: center; }
  .hero-stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; font-weight: 600;
    color: var(--gold);
    display: block;
  }
  .hero-stat-label { font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); }

  /* ─── SEARCH SECTION ─── */
  .search-section {
    padding: 0 2rem 5rem;
    display: flex; flex-direction: column; align-items: center;
    position: relative; z-index: 2;
  }

  .search-bar {
    width: 100%; max-width: 760px;
    display: flex; align-items: center; gap: 12px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 4px 4px 4px 18px;
    transition: border-color 0.2s;
    margin-bottom: 1rem;
  }
  .search-bar:focus-within { border-color: var(--gold); }

  .search-bar input {
    flex: 1; background: transparent; border: none; outline: none;
    color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 15px;
    padding: 10px 0;
  }
  .search-bar input::placeholder { color: var(--text3); }

  .search-bar button {
    padding: 10px 24px;
    background: var(--gold); border: none; border-radius: 5px;
    color: #0d1117; font-family: 'DM Sans', sans-serif; font-size: 14px; font-weight: 500;
    cursor: pointer;
  }

  .filter-pills {
    display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;
  }

  .filter-pill {
    padding: 5px 14px;
    border: 1px solid var(--border2);
    border-radius: 20px;
    background: transparent;
    color: var(--text2);
    font-size: 12px; font-family: 'DM Sans', sans-serif;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-pill:hover, .filter-pill.active {
    border-color: var(--gold);
    color: var(--gold);
    background: var(--gold-dim);
  }

  /* ─── SECTION SHARED ─── */
  section { padding: 5rem 3rem; }

  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-eyebrow {
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 0.75rem;
  }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .section-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 300;
    color: var(--text2);
    max-width: 500px;
    margin: 0 auto;
  }

  /* ─── MONUMENTS GRID ─── */
  .monuments-section { background: var(--bg); padding-top: 2rem; }

  .monuments-toolbar {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 2rem; flex-wrap: wrap;
  }

  .monuments-count {
    font-size: 13px; color: var(--text2);
    margin-right: auto;
  }
  .monuments-count strong { color: var(--text); }

  .sort-select {
    background: var(--bg2); border: 1px solid var(--border2);
    color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 13px;
    padding: 7px 14px; border-radius: 6px; cursor: pointer;
    outline: none;
  }

  .view-toggle {
    display: flex; border: 1px solid var(--border2); border-radius: 6px; overflow: hidden;
  }

  .view-btn {
    padding: 7px 12px; background: transparent;
    border: none; color: var(--text3); cursor: pointer;
    font-size: 14px; transition: all 0.2s;
  }
  .view-btn.active { background: var(--gold-dim); color: var(--gold); }

  .monuments-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .monument-card {
    background: var(--card);
    border: 1px solid var(--border2);
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
    animation: card-in 0.5s ease both;
  }

  @keyframes card-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .monument-card:hover {
    transform: translateY(-4px);
    border-color: rgba(212,168,67,0.35);
    box-shadow: 0 16px 48px rgba(0,0,0,0.4);
  }

  .card-img {
    position: relative;
    height: 220px;
    overflow: hidden;
  }

  .card-img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.4s;
  }
  .monument-card:hover .card-img img { transform: scale(1.05); }

  .card-badge {
    position: absolute; top: 12px; left: 12px;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 10px; font-weight: 500; letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .badge-unesco { background: #1a6fc4; color: #fff; }
  .badge-heritage { background: rgba(212,168,67,0.9); color: #0d1117; }

  .card-save {
    position: absolute; top: 12px; right: 12px;
    width: 32px; height: 32px;
    background: rgba(13,17,23,0.7);
    border: 1px solid var(--border2);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; font-size: 14px;
    transition: background 0.2s, border-color 0.2s;
  }
  .card-save:hover { background: var(--gold-dim); border-color: var(--gold); }

  .card-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 60px;
    background: linear-gradient(to top, rgba(13,17,23,0.9), transparent);
  }

  .card-location {
    position: absolute; bottom: 10px; left: 12px;
    font-size: 11px; color: rgba(255,255,255,0.7);
    display: flex; align-items: center; gap: 4px;
  }

  .card-body { padding: 16px; }

  .card-tags {
    display: flex; gap: 6px; flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .card-tag {
    padding: 2px 9px;
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 10px;
    color: var(--gold);
    letter-spacing: 0.04em;
  }

  .card-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem; font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }

  .card-desc {
    font-size: 12px; color: var(--text2); line-height: 1.6;
    margin-bottom: 14px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-footer {
    display: flex; align-items: center; justify-content: space-between;
    padding-top: 12px;
    border-top: 1px solid var(--border2);
  }

  .card-rating {
    display: flex; align-items: center; gap: 4px;
    font-size: 12px; color: var(--text2);
  }
  .card-rating .star { color: var(--gold); }

  .card-cta {
    font-size: 12px; color: var(--gold); font-weight: 500;
    letter-spacing: 0.04em;
  }

  /* ─── FEATURES STRIP ─── */
  .features-section {
    background: var(--bg2);
    border-top: 1px solid var(--border2);
    border-bottom: 1px solid var(--border2);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    text-align: center;
    padding: 2rem 1.5rem;
    border-radius: 10px;
    border: 1px solid transparent;
    transition: border-color 0.3s, background 0.3s;
    cursor: pointer;
  }
  .feature-card:hover {
    border-color: var(--border);
    background: var(--bg3);
  }

  .feature-icon {
    width: 52px; height: 52px;
    background: var(--gold-dim);
    border: 1px solid var(--border);
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    margin: 0 auto 1rem;
  }

  .feature-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem; font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }

  .feature-desc { font-size: 12px; color: var(--text2); line-height: 1.6; }

  /* ─── TIMELINE ─── */
  .timeline-section { background: var(--bg); }

  .timeline {
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 50%; transform: translateX(-50%);
    top: 0; bottom: 0; width: 1px;
    background: linear-gradient(to bottom, transparent, var(--gold), var(--gold), transparent);
    opacity: 0.3;
  }

  .timeline-item {
    display: flex; gap: 2rem;
    margin-bottom: 3rem;
    position: relative;
  }

  .timeline-item:nth-child(even) { flex-direction: row-reverse; }

  .timeline-content {
    flex: 1;
    background: var(--card);
    border: 1px solid var(--border2);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    transition: border-color 0.2s;
  }
  .timeline-content:hover { border-color: var(--border); }

  .timeline-dot {
    width: 14px; height: 14px;
    background: var(--gold);
    border-radius: 50%;
    border: 3px solid var(--bg);
    position: absolute;
    left: 50%; transform: translateX(-50%);
    top: 1.25rem;
    z-index: 1;
  }

  .timeline-era {
    font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 4px;
  }

  .timeline-year {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem; font-weight: 600;
    color: var(--text); margin-bottom: 4px;
  }

  .timeline-event { font-size: 13px; color: var(--text2); }

  .timeline-space { flex: 1; }

  /* ─── AI SECTION ─── */
  .ai-section {
    background: var(--bg2);
    border-top: 1px solid var(--border2);
  }

  .ai-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  .ai-chat {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .chat-header {
    padding: 14px 18px;
    background: var(--bg3);
    border-bottom: 1px solid var(--border2);
    display: flex; align-items: center; gap: 10px;
  }

  .chat-avatar {
    width: 32px; height: 32px;
    background: var(--gold);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px;
  }

  .chat-info strong { font-size: 13px; color: var(--text); display: block; }
  .chat-info span { font-size: 11px; color: #4caf7d; }

  .chat-messages { padding: 16px; display: flex; flex-direction: column; gap: 12px; }

  .msg {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 10px;
    font-size: 13px; line-height: 1.5;
  }

  .msg-ai {
    background: var(--bg3);
    border: 1px solid var(--border2);
    color: var(--text2);
    align-self: flex-start;
  }

  .msg-user {
    background: var(--gold-dim);
    border: 1px solid var(--border);
    color: var(--text);
    align-self: flex-end;
  }

  .chat-input-row {
    display: flex; gap: 8px;
    padding: 12px 16px;
    border-top: 1px solid var(--border2);
  }

  .chat-input {
    flex: 1; background: var(--bg3);
    border: 1px solid var(--border2); border-radius: 6px;
    color: var(--text); font-family: 'DM Sans', sans-serif; font-size: 13px;
    padding: 8px 12px; outline: none;
    transition: border-color 0.2s;
  }
  .chat-input:focus { border-color: var(--gold); }

  .chat-send {
    padding: 8px 16px; background: var(--gold);
    border: none; border-radius: 6px; color: #0d1117;
    font-size: 13px; font-weight: 500; cursor: pointer;
  }

  .ai-copy { }

  .ai-copy h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.25rem; font-weight: 600;
    color: var(--text); margin-bottom: 1rem;
  }

  .ai-copy p {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 300;
    color: var(--text2); line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .ai-features { display: flex; flex-direction: column; gap: 10px; }

  .ai-feat {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px; color: var(--text2);
  }

  .ai-feat-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--gold); flex-shrink: 0;
  }

  /* ─── STATES ─── */
  .states-section { background: var(--bg); }

  .states-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }

  .state-card {
    background: var(--card);
    border: 1px solid var(--border2);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.2s;
  }
  .state-card:hover {
    border-color: var(--border);
    background: var(--bg3);
    transform: translateY(-2px);
  }

  .state-icon { font-size: 2rem; margin-bottom: 8px; }

  .state-name {
    font-family: 'Playfair Display', serif;
    font-size: 0.9rem; color: var(--text); font-weight: 600;
    margin-bottom: 2px;
  }

  .state-count { font-size: 11px; color: var(--text3); }

  /* ─── PRICING ─── */
  .pricing-section { background: var(--bg2); border-top: 1px solid var(--border2); }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .pricing-card {
    background: var(--card);
    border: 1px solid var(--border2);
    border-radius: 14px;
    padding: 2rem;
    position: relative;
    transition: transform 0.25s;
  }
  .pricing-card:hover { transform: translateY(-4px); }

  .pricing-card.featured {
    border-color: var(--gold);
    background: var(--bg3);
  }

  .pricing-popular {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    background: var(--gold); color: #0d1117;
    padding: 3px 14px; border-radius: 20px;
    font-size: 10px; font-weight: 500; letter-spacing: 0.08em;
